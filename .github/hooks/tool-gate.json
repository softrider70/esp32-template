{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "description": "Minimal tool policy for the template workspace",
  "hooks": {
    "PreToolUse": [
      {
        "type": "command",
        "command": "pwsh -File .github/hooks/scripts/pre_tool_use.ps1",
        "windows": "pwsh -File .github\\hooks\\scripts\\pre_tool_use.ps1",
        "timeout": 10
      }
    ]
  }
}
