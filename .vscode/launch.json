{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "ESP-IDF GDB",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/build/${command:espIdf.getProjectName}.elf",
            "args": [],
            "stopAtEntry": true,
            "cwd": "${workspaceFolder}",
            "environment": [],
            "externalConsole": false,
            "MIMode": "gdb",
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                },
                {
                    "text": "target remote //${config:idf.port}:3333",
                    "ignoreFailures": false
                },
                {
                    "text": "monitor reset",
                    "ignoreFailures": false
                },
                {
                    "text": "monitor halt",
                    "ignoreFailures": false
                },
                {
                    "text": "flushregs",
                    "ignoreFailures": false
                }
            ],
            "preLaunchTask": "esp-idf: flash",
            "miDebuggerServerAddress": "localhost:3333"
        }
    ]
}
